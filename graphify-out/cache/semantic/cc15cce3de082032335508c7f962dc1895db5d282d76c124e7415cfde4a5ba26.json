{"nodes": [{"id": "resolucion_59_2019_cs", "label": "Resoluci\u00f3n CS N\u00b059/2019 \u2013 Espectro Radioel\u00e9ctrico/Cap 60 MHz (SUBTEL)", "file_type": "document", "source_file": "raw-md/resoluciones-cs-md/Resolucion_59_2019_CS.md", "source_location": null, "source_url": null, "captured_at": "2020-07-13", "author": "Tercera Sala CS", "contributor": null}, {"id": "concepto_espectro_radioelectrico", "label": "Espectro Radioel\u00e9ctrico / Cap de Tenencia", "file_type": "rationale", "source_file": "raw-md/resoluciones-cs-md/Resolucion_59_2019_CS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "La Resoluci\u00f3n N\u00b059/2019 CS (ex TDLC) resuelve la consulta de la Subsecretar\u00eda de Telecomunicaciones sobre el cap de 60 MHz por operador m\u00f3vil. El espectro es un insumo esencial, escaso y finito. La CS revisa la vigencia del l\u00edmite fijado en 2009 (Rol 4797-2008). Antecedentes relevantes incluyen Resoluci\u00f3n N\u00b0588/2000 CR (30 MHz), Resoluci\u00f3n TDLC N\u00b02/2005 (cap 60 MHz como condici\u00f3n de fusi\u00f3n Movistar-BellSouth), y Resoluci\u00f3n TDLC N\u00b027/2008 (participaci\u00f3n de incumbentes en concurso 3G). El mercado relevante incluye telecom m\u00f3vil con tres insumos esenciales: espectro, infraestructura y tecnolog\u00eda."}, {"id": "entidad_subtel", "label": "Subsecretar\u00eda de Telecomunicaciones (SUBTEL)", "file_type": "document", "source_file": "raw-md/resoluciones-cs-md/Resolucion_59_2019_CS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "resolucion_59_2019_cs", "target": "concepto_mercado_relevante", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_59_2019_CS.md", "source_location": "Servicios de telecomunicaciones m\u00f3viles como mercado relevante", "weight": 1.0}, {"source": "r