{"nodes": [{"id": "resolucion_65_2021_cs", "label": "Resoluci\u00f3n CS N\u00b065/2021 \u2013 Cencosud/Valdivia (Modificaci\u00f3n Condici\u00f3n Fusi\u00f3n SMU-SDS)", "file_type": "document", "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": null, "source_url": null, "captured_at": "2022-07-25", "author": "Tercera Sala CS", "contributor": null}, {"id": "concepto_operacion_concentracion", "label": "Operaci\u00f3n de Concentraci\u00f3n", "file_type": "rationale", "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "La Resoluci\u00f3n N\u00b065/2021 CS analiza el alzamiento de una condici\u00f3n de la Resoluci\u00f3n N\u00b043/2012 TDLC (fusi\u00f3n SMU-SDS), aplicando criterio de cambio de circunstancias: descenso del HHI desde 2012, ingreso de 5 nuevos supermercados en Valdivia, irrecuperabilidad de la condici\u00f3n original por quiebra de Bigger. La CS aprueba el alzamiento. En la Resoluci\u00f3n N\u00b051/2018 CS, se analiza la adquisici\u00f3n de CGE por Gas Natural Fenosa, con atenci\u00f3n al HHI de 3.300 y los riesgos de integraci\u00f3n vertical y horizontal en el mercado del gas."}, {"id": "concepto_hhi", "label": "\u00cdndice Herfindahl-Hirschman (HHI)", "file_type": "rationale", "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "El HHI es utilizado como m\u00e9trica de concentraci\u00f3n en la Resoluci\u00f3n N\u00b065/2021 CS (reducci\u00f3n desde 2012 como argumento para alzar condici\u00f3n de fusi\u00f3n) y en la Resoluci\u00f3n N\u00b051/2018 CS (3.300 puntos en mercado de gas, 'altamente concentrado'). Es una metodolog\u00eda econ\u00f3mica validada impl\u00edcitamente por la CS como indicador de concentraci\u00f3n de mercado."}, {"id": "concepto_cambio_circunstancias", "label": "Cambio de Circunstancias / Modificaci\u00f3n de Condiciones", "file_type": "rationale", "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "La Resoluci\u00f3n N\u00b065/2021 CS aprueba el alzamiento de una condici\u00f3n de fusi\u00f3n (Resoluci\u00f3n TDLC N\u00b043/2012) por cambio de circunstancias: ingreso de nuevos competidores, desconcentraci\u00f3n del mercado, quiebra del adquirente original (Bigger), e imposibilidad material de cumplir la condici\u00f3n original. La Resoluci\u00f3n N\u00b067/2021 CS analiza si el paso del M3P al M4P en medios de pago constituye cambio de circunstancias suficiente para reemplazar el PAR: concluye que hubo cambio f\u00e1ctico/econ\u00f3mico pero la transici\u00f3n no est\u00e1 completa (falta regulaci\u00f3n de tasas de intercambio). Ambas resoluciones aplican un test de cambio de circunstancias para modificar condiciones previas."}, {"id": "entidad_cencosud", "label": "Cencosud S.A.", "file_type": "document", "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "resolucion_65_2021_cs", "target": "concepto_operacion_concentracion", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "An\u00e1lisis Resoluci\u00f3n TDLC N\u00b043/2012 fusi\u00f3n SMU-SDS", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "concepto_hhi", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "Argumento HHI actual menor al previo a la operaci\u00f3n", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "concepto_remedio_condicion", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "Alzamiento condici\u00f3n primera Resoluci\u00f3n N\u00b043", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "concepto_cambio_circunstancias", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "An\u00e1lisis cambio de circunstancias desde 2012", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "concepto_mercado_relevante", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "Mercado supermercadista Valdivia", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "concepto_procedimiento_no_contencioso", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "Naturaleza del procedimiento de consulta", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "entidad_cencosud", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "Vistos - consultante", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "entidad_fne", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "Aportantes de antecedentes", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "entidad_conadecus", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": "Aportantes de antecedentes", "weight": 1.0}, {"source": "resolucion_65_2021_cs", "target": "resolucion_51_2018_cs", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.65, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": null, "weight": 0.65}, {"source": "concepto_operacion_concentracion", "target": "concepto_remedio_condicion", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": null, "weight": 0.95}, {"source": "concepto_cambio_circunstancias", "target": "concepto_remedio_condicion", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "raw-md/resoluciones-cs-md/Resolucion_65_2021_CS.md", "source_location": null, "weight": 0.85}], "hyperedges": []}